# Supabase Config
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Mercado Pago Config
MP_ACCESS_TOKEN=APP_USR-xxxx-xxxx-xxxx
MP_WEBHOOK_SECRET=your_mp_webhook_secret

# Resend Mail Config
RESEND_API_KEY=re_xxxx_xxxx

# JWT Auth Keys (RS256)
# Debe ser una clave RSA codificada en formato PEM y escapada en una sola línea con '\n'
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...\n-----END PUBLIC KEY-----"
